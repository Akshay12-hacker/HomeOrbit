{
  "expo": {
    "name": "HomeOrbit",
    "slug": "HomeOrbit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/essentials/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.akshay12hacker.HomeOrbit"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "49170853-0c98-44e7-b72c-b284bb48424c"
      }
    },
    "plugins": [
      "expo-secure-store",
      "./plugins/withAndroidCleartext",
      "@sentry/react-native"
    ]
  }
}
